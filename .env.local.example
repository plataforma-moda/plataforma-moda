# ==============================================================
# SNM - Sistema Nacional da Moda
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local com valores reais
# ==============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - apenas server-side (webhooks)
# Nao use NEXT_PUBLIC_ para esta chave
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Mercado Pago ---
# Access token do seller (sandbox ou producao)
# Obtenha em: https://www.mercadopago.com.br/developers/pt/docs/checkout-pro/additional-content/your-integrations/credentials
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...

# Public key - pode ser exposta no client
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-...

# --- App ---
# URL publica do app (sem barra final)
# Sandbox: http://localhost:3000
# Producao: https://snmoda.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Webhook ---
# URL que o Mercado Pago usara para enviar notificacoes
# Em desenvolvimento: use ngrok ou similar para expor localhost
# Em producao: https://snmoda.com.br/api/billing/webhooks
# Configure em: https://www.mercadopago.com.br/developers/pt/docs/checkout-pro/additional-content/your-integrations/notifications

# --- Email (Resend) ---
# Servico de email transacional: https://resend.com
# Passos para configurar:
#   1. Crie uma conta gratuita em resend.com (3.000 emails/mes gratis)
#   2. Verifique seu dominio (snmoda.com.br) em Resend > Domains
#   3. Gere uma API Key em Resend > API Keys
#   4. Preencha as variaveis abaixo
# Documentacao: https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remetente dos emails transacionais
# Deve usar o dominio verificado no Resend
# Exemplo: noreply@snmoda.com.br
EMAIL_FROM=SNM - Sistema Nacional da Moda <noreply@snmoda.com.br>

# --- Cloudflare Turnstile (CAPTCHA) ---
# Cadastre um site em https://dash.cloudflare.com/turnstile
# Use "Managed" mode para melhor UX
# Em desenvolvimento: use as chaves de teste abaixo (sempre passam)
# Site key de teste:  1x00000000000000000000AA
# Secret key de teste: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
